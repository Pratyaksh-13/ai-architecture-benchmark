# Backend
DATABASE_URL=postgresql://postgres:password@localhost:5432/archbench
REDIS_URL=redis://localhost:6379/1
RESULT_BACKEND_URL=redis://localhost:6379/2
OPENAI_API_KEY=your-openrouter-key-here
OPENAI_BASE_URL=https://openrouter.ai/api/v1
LLM_PROVIDER=openai

# Benchmark service URLs (set to Render service URLs in production)
